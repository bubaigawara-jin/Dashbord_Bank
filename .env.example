# Copiez ce fichier en ".env" (ou exportez ces variables dans votre shell)
# et ajustez les valeurs selon votre serveur MySQL local.
#
# Usage avec un fichier .env :
#   pip install python-dotenv
#   puis, en haut de db_connection.py : from dotenv import load_dotenv; load_dotenv()
#
# Usage direct dans le shell (sans .env) :
#   export DB_HOST=localhost
#   export DB_PORT=3306
#   export DB_USER=root
#   export DB_PASSWORD=motdepasse
#   export DB_NAME=bi_fraude

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changez_moi
DB_NAME=bi_fraude
